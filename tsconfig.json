{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "app/**/*.ts",
    "browser/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts",
    "vite.config.ts",
    "vite.lib.config.ts"
  ]
}
